# Google AI Studio (Gemini) — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Alias alternativo (opcional)
# GEMINI_API_KEY=

# Modelo opcional (por defecto: gemini-2.0-flash)
# Otros gratuitos/económicos: gemini-2.0-flash-lite, gemini-2.5-flash
# GEMINI_MODEL=gemini-2.0-flash

# Desactivar IA completamente (usar solo plantillas locales)
# DISABLE_AI=true
